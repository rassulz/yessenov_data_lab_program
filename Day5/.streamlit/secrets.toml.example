# Template for secrets. SAFE to commit (no real keys here).
# Copy this file to secrets.toml and put your real keys in that copy.
# secrets.toml is in .gitignore and must NEVER be committed.

# gemma4 (LLM) — OpenAI-compatible API on alem.ai
GEMMA4_API_KEY = ""
GEMMA4_MODEL   = "gemma4"
GEMMA4_BASE_URL = "https://llm.alem.ai/v1"

# text-1024 (embedding model, 1024-dim)
EMBED_API_KEY = ""
EMBED_MODEL   = "text-1024"
EMBED_BASE_URL = "https://llm.alem.ai/v1"

# MailerSend (email) — optional fallback. The shared course key is in the project PDF.
MAILERSEND_API_KEY = ""
SENDER_EMAIL = "info@app.commit.kz"

# Gmail SMTP — the working email transport. Create an App Password:
#   Google Account -> Security -> 2-Step Verification -> App passwords.
GMAIL_ADDRESS = ""
GMAIL_APP_PASSWORD = ""

# Email feature: ONLY ever send to your own inbox.
ADMIN_EMAIL = ""
